       <property name="styleSheet">
        <string notr="true">QPushButton {
    /* 去掉边框和默认背景 */
	background: #FFF;  
	border-radius: 2px;
    color: #cccccc;           /* 文字颜色 */
}

/* 关键：必须覆盖 hover，否则 Qt 默认会画灰色渐变 */
QPushButton:hover {
    background: #ccc;  
    color: #ffffff;           /* 可以让文字变亮，但背景不动 */
    border: none;
}

/* 按下效果也去掉（可选，建议保留一点点反馈）*/
QPushButton:pressed {
    background: transparent;
}</string>
