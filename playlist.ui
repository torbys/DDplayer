     <property name="styleSheet">
      <string notr="true">/* ========== PlayList 整体 ========== */
PlayList {
    background-color: #171D1D; /* 使用深黑灰作为总背景 */
    border: none;
}

/* ========== 列表区域 ========== */
QListWidget#videoList {
    background-color: #171D1D; /* 深黑灰背景 */
    border: 1px solid #69655B; /* 褐灰边框，低调且有质感 */
    outline: none;
    show-decoration-selected: 0;
}

/* ========== Item 基础 ========== */
QListWidget#videoList::item {
    font-weight: bold;
    background-color: #171D1D; /* 默认背景色 */
    color: #DBDBD8; /* 浅灰白文字，柔和不刺眼 */
    padding: 6px 8px;
    margin: 4px 8px;  
    height: 70px;
    border-radius: 4px; /* 增加微小圆角提升现代感 */
}

/* ========== Item 悬停 ========== */
QListWidget#videoList::item:hover {
    background-color: rgba(0,0,0,0.1); /* 冷灰悬停，产生金属铝材的视觉感 */
    color: #FFFFFF; /* 悬停时文字纯白 */
}

/* ========== Item 选中 ========== */
QListWidget#videoList::item:selected {
    background-color: rgba(0,0,0,1);/* 暖黄/金色选中态，典型的“高级黑金”配色 */
    color: #171D1D; /* 选中时文字变为深色，保证极高辨识度 */
    font-weight: bold;
}

/* 选中态的悬停（保持金色） */
QListWidget#videoList::item:selected:hover {
    background-color: rgba(0,0,0,0.2);
    color: #171D1D;
}

/* ========== 滚动条美化 ========== */
/* 竖直滚动条整体 */
QListWidget#videoList QScrollBar:vertical {
    background-color: #171D1D;
    width: 8px;
    border-radius: 4px;
    margin: 4px 0;
}

/* 滚动条滑块 */
QListWidget#videoList QScrollBar::handle:vertical {
    background-color: #69655B; /* 褐灰滑块，与背景融合 */
    min-height: 30px;
    border-radius: 4px;
    margin: 0 2px;
}

/* 滑块悬停 */
QListWidget#videoList QScrollBar::handle:vertical:hover {
    background-color: #8B8D95; /* 冷灰，增加亮度反馈 */
}

/* 滑块按下 */
QListWidget#videoList QScrollBar::handle:vertical:pressed {
    background-color: #D5B44F; /* 按下时变为金色反馈 */
}

/* 去掉上下箭头按钮 */
QListWidget#videoList QScrollBar::add-line:vertical,
QListWidget#videoList QScrollBar::sub-line:vertical {
    height: 0px;
    background: transparent;
}

/* 滚动条背景槽 */
QListWidget#videoList QScrollBar::add-page:vertical,
QListWidget#videoList QScrollBar::sub-page:vertical {
    background-color: transparent;
}</string>
     </property>
